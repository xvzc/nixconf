#!/usr/bin/env bash

# Resolves context identifiers from arguments or active environment
CUR_SESSION_NAME="${1:-$(tmux display-message -p '#{session_name}')}"
CUR_WIN_ID="${2:-$(tmux display-message -p '#{window_id}')}"

# Provisions a persistent background session for opencode management
HIDDEN_SESSION="__opencode_session"
if ! tmux has-session -t "$HIDDEN_SESSION" 2>/dev/null; then
  tmux new-session -d -s "$HIDDEN_SESSION" -n "__keepalive" "tail -f /dev/null"
fi

# Retrieves the opencode pane identifier from the explicit session scope
OPENV_PANE_ID=$(tmux show-option -t "$CUR_SESSION_NAME" -v @opencode_pane_id 2>/dev/null)

# Evaluates the presence of the opencode pane within the target window
IS_VISIBLE=0
if [ -n "$OPENV_PANE_ID" ] && tmux list-panes -t "$CUR_WIN_ID" -F '#{pane_id}' 2>/dev/null | grep -q "^${OPENV_PANE_ID}$"; then
  IS_VISIBLE=1
fi

if [ "$IS_VISIBLE" -eq 1 ]; then
  # --- [HIDE] Migrates the opencode pane to background storage ---
  CURRENT_WIDTH=$(tmux display-message -p -t "$OPENV_PANE_ID" '#{pane_width}')
  tmux set-option -t "$CUR_SESSION_NAME" @opencode_width "$CURRENT_WIDTH"

  tmux kill-window -t "${HIDDEN_SESSION}:${CUR_SESSION_NAME}" 2>/dev/null
  tmux break-pane -d -s "$OPENV_PANE_ID" -t "${HIDDEN_SESSION}:" -n "${CUR_SESSION_NAME}"
else
  # --- [SHOW] Reattaches or initializes the opencode pane ---

  # Calculates target width (33% default ratio)
  SAVED_WIDTH=$(tmux show-option -t "$CUR_SESSION_NAME" -v @opencode_width 2>/dev/null)
  if [ -z "$SAVED_WIDTH" ]; then
    WIN_WIDTH=$(tmux display-message -p -t "$CUR_WIN_ID" '#{window_width}')
    TARGET_WIDTH=$((WIN_WIDTH * 33 / 100))
    [ "$TARGET_WIDTH" -lt 10 ] && TARGET_WIDTH=10
  else
    TARGET_WIDTH="$SAVED_WIDTH"
  fi

  # PROJECT_ROOT extraction and cleansing
  RAW_ENV=$(tmux show-environment -t "$CUR_SESSION_NAME" PROJECT_ROOT 2>/dev/null | grep "^PROJECT_ROOT=")
  TARGET_DIR="${RAW_ENV#PROJECT_ROOT=}"
  TARGET_DIR=$(echo "$TARGET_DIR" | tr -d '\r\n' | sed 's/^"//;s/"$//' | xargs)
  [ -z "$TARGET_DIR" ] || [ ! -d "$TARGET_DIR" ] && TARGET_DIR=$(tmux display-message -p -t "$CUR_WIN_ID" '#{pane_current_path}')

  # Define the specific command to execute (Port 8080 added as default)
  OPEN_CMD="opencode . --port"

  if [ -n "$OPENV_PANE_ID" ] && tmux list-panes -a -F '#{pane_id}' | grep -q "^${OPENV_PANE_ID}$"; then
    # Reattach existing pane
    tmux join-pane -f -h -s "$OPENV_PANE_ID" -t "$CUR_WIN_ID" -l "$TARGET_WIDTH"
    tmux select-pane -t "$OPENV_PANE_ID"
  else
    # Initialize NEW pane with the command on the right side (-h)
    NEW_ID=$(tmux split-window -t "$CUR_WIN_ID" -c "$TARGET_DIR" -f -h -P -F '#{pane_id}' -l "$TARGET_WIDTH" "$OPEN_CMD")
    tmux set-option -t "$CUR_SESSION_NAME" @opencode_pane_id "$NEW_ID"
    tmux select-pane -t "$NEW_ID"
  fi
fi
